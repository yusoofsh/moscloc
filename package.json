{
	"name": "moscloc",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"serve": "vite preview",
		"check": "nub run format:check && nub run lint && tsc --noEmit",
		"check:fix": "nub run format && nub run lint:fix",
		"check-types": "tsc --noEmit",
		"format": "oxfmt --write . '!lock.yaml'",
		"format:check": "oxfmt --check . '!lock.yaml'",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix .",
		"test": "nub run check && nub run test:coverage && nub run test:browser && nub run test:e2e",
		"test:headed": "playwright test --headed",
		"test:ui": "playwright test --ui",
		"test:report": "playwright show-report",
		"test:unit": "vitest run",
		"test:unit:coverage": "vitest run --coverage",
		"test:unit:watch": "vitest",
		"test:browser": "vitest run --config vitest.browser.config.ts",
		"test:browser:watch": "vitest --config vitest.browser.config.ts",
		"test:vitest": "vitest run",
		"test:vitest:watch": "vitest",
		"test:coverage": "nub run test:unit:coverage",
		"test:e2e": "playwright test",
		"deploy": "nub run build && wrangler deploy",
		"preview": "nub run build && wrangler dev"
	},
	"dependencies": {
		"@playwright/test": "^1.61.1",
		"@tailwindcss/vite": "^4.3.2",
		"@tanstack/react-router": "1.170.17",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.23.0",
		"radix-ui": "^1.6.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"shadcn": "^4.13.0",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@tanstack/react-router-devtools": "^1.167.0",
		"@tanstack/router-plugin": "^1.168.19",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^26.1.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"@vitest/browser-playwright": "4.1.9",
		"@vitest/coverage-v8": "4.1.9",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lint-staged": "^17.0.8",
		"msw": "^2.14.6",
		"oxfmt": "^0.57.0",
		"oxlint": "^1.72.0",
		"playwright": "^1.61.1",
		"tailwindcss": "^4.3.2",
		"typescript": "6.0.3",
		"vite": "8.1.3",
		"vitest": "4.1.9",
		"vitest-browser-react": "^2.2.0",
		"wrangler": "^4.93.0"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx}": [
			"oxlint --fix --no-error-on-unmatched-pattern",
			"oxfmt --write --no-error-on-unmatched-pattern"
		],
		"!(*lock).{json,jsonc,css,scss,md,mdx,yml,yaml,html}": [
			"oxfmt --write --no-error-on-unmatched-pattern"
		]
	},
	"devEngines": {
		"packageManager": {
			"name": "nub",
			"version": "^0.2.10",
			"onFail": "warn"
		}
	},
	"packageManager": "nub@0.2.10",
	"msw": {
		"workerDirectory": [
			"public"
		]
	}
}
