{
	"compilerOptions": {
		"strict": true,
		"esModuleInterop": true,
		"jsx": "react-jsx",
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"types": [
			"vite/client",
			"vitest/globals",
			"@testing-library/jest-dom/vitest"
		],
		"rootDirs": ["."],
		"paths": {
			"~/*": ["./src/*"]
		}
	}
}
