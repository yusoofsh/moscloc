{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "moscloc",
	"version": "0.1.0",
	"identifier": "com.tauri.dev",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:5173",
		"beforeDevCommand": "nub run dev",
		"beforeBuildCommand": "nub run build"
	},
	"app": {
		"windows": [
			{
				"title": "moscloc",
				"width": 800,
				"height": 600,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"capabilities": ["main"],
			"csp": {
				"default-src": "'self'",
				"base-uri": "'self'",
				"connect-src": "'self' ipc: http://ipc.localhost https://api.aladhan.com",
				"font-src": "'self' data: https://fonts.gstatic.com",
				"frame-ancestors": "'none'",
				"img-src": "'self' data: asset: http://asset.localhost https://i.postimg.cc",
				"object-src": "'none'",
				"script-src": "'self'",
				"style-src": "'self' 'unsafe-inline' https://fonts.googleapis.com"
			}
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
